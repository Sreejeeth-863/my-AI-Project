import React, { useState, useRef, useEffect } from 'react';
import { Send, Heart, Star, Lightbulb, Music, ArrowRight } from 'lucide-react';

export default function BuddyPals() {
  const [selectedCharacter, setSelectedCharacter] = useState(null);
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [mood, setMood] = useState('good');
  const messagesEndRef = useRef(null);

  const characters = [
    {
      id: 'sunny',
      name: 'Sunny',
      emoji: '☀️',
      color: '#FFB84D',
      role: 'Your Happy Friend',
      description: 'Always cheerful and ready to chat!',
      personality: 'You are Sunny, an extremely cheerful and optimistic AI friend. You love making children laugh with silly jokes and positive energy. You listen to their feelings with warmth and always find something bright to say. Keep responses short, fun, and encouraging. Use emojis and exclamation marks!',
    },
    {
      id: 'luna',
      name: 'Luna',
      emoji: '🌙',
      color: '#9B7EF5',
      role: 'Your Calm Listener',
      description: 'Here to listen and understand',
      personality: 'You are Luna, a calm and gentle AI friend. You\'re like a peaceful night sky - quiet, thoughtful, and deeply understanding. You help children feel safe sharing their feelings. You give advice gently and remind them they\'re not alone. Keep responses warm and soothing.',
    },
    {
      id: 'spark',
      name: 'Spark',
      emoji: '⚡',
      color: '#FF6B9D',
      role: 'Your Creative Buddy',
      description: 'Let\'s create and have fun!',
      personality: 'You are Spark, a creative and imaginative AI friend who loves ideas and activities! You suggest fun things to do, cool games to play, and creative projects. You\'re energetic and exciting. Suggest 2-3 fun activities they could do right now. Keep it brief and exciting!',
    },
    {
      id: 'wise',
      name: 'Wise Owl',
      emoji: '🦉',
      color: '#6ECB63',
      role: 'Your Wise Guide',
      description: 'Here to help you grow',
      personality: 'You are Wise Owl, thoughtful and kind. You help children understand their feelings and learn new things. You share helpful advice and encourage good choices. You speak like a caring mentor. Keep responses encouraging and age-appropriate.',
    },
  ];

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  const sendMessage = async () => {
    if (!input.trim() || !selectedCharacter || loading) return;

    const userMessage = input;
    setInput('');
    setMessages(prev => [...prev, { role: 'user', content: userMessage }]);
    setLoading(true);

    try {
      const character = characters.find(c => c.id === selectedCharacter);
      
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 300,
          messages: [
            {
              role: 'user',
              content: ${character.personality}\n\nChild says: "${userMessage}"\n\nRespond as ${character.name} in a way that's helpful, warm, and age-appropriate.
            }
          ],
        })
      });

      const data = await response.json();
      const aiResponse = data.content[0].text;
      setMessages(prev => [...prev, { role: 'assistant', content: aiResponse }]);
    } catch (error) {
      console.error('Error:', error);
      setMessages(prev => [...prev, { 
        role: 'assistant', 
        content: 'Oops! I had a little trouble there. Try again!' 
      }]);
    }

    setLoading(false);
  };

  if (!selectedCharacter) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-blue-100 via-purple-100 to-pink-100 p-4 sm:p-8">
        {/* Animated background elements */}
        <div className="fixed inset-0 overflow-hidden pointer-events-none">
          <div className="absolute top-10 left-10 w-20 h-20 rounded-full bg-yellow-200 opacity-20 animate-pulse"></div>
          <div className="absolute bottom-32 right-20 w-32 h-32 rounded-full bg-purple-200 opacity-20 animate-pulse" style={{animationDelay: '1s'}}></div>
          <div className="absolute top-1/2 left-1/3 w-24 h-24 rounded-full bg-pink-200 opacity-20 animate-pulse" style={{animationDelay: '0.5s'}}></div>
        </div>

        <div className="relative max-w-6xl mx-auto">
          {/* Header */}
          <div className="text-center mb-12 sm:mb-16 animate-fadeIn">
            <h1 className="text-5xl sm:text-6xl font-black mb-4 text-transparent bg-clip-text bg-gradient-to-r from-purple-600 via-pink-600 to-red-600" style={{fontFamily: 'Comic Sans MS, cursive, sans-serif'}}>
              🌟 Buddy Pals 🌟
            </h1>
            <p className="text-xl sm:text-2xl text-gray-700 font-semibold mb-4">
              You're never alone! Choose a friend to talk to.
            </p>
            <p className="text-sm text-gray-600">
              Everyone feels lonely sometimes. Our AI friends are here to listen, help, and make you smile. 💙
            </p>
          </div>

          {/* Mood Check-in */}
          <div className="mb-12 max-w-xl mx-auto">
            <p className="text-center font-bold text-gray-700 mb-4">How are you feeling today?</p>
            <div className="flex gap-3 justify-center flex-wrap">
              {['sad', 'okay', 'good', 'amazing'].map(m => (
                <button
                  key={m}
                  onClick={() => setMood(m)}
                  className={`px-4 py-2 rounded-full font-bold capitalize transition-all transform hover:scale-110 ${
                    mood === m 
                      ? 'bg-gradient-to-r from-purple-500 to-pink-500 text-white scale-110 shadow-lg' 
                      : 'bg-white text-gray-700 shadow'
                  }`}
                >
                  {m === 'sad' && '😢'} {m === 'okay' && '😐'} {m === 'good' && '😊'} {m === 'amazing' && '🤩'} {m}
                </button>
              ))}
            </div>
          </div>

          {/* Character Selection Grid */}
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
            {characters.map(char => (
              <button
                key={char.id}
                onClick={() => {
                  setSelectedCharacter(char.id);
                  setMessages([]);
                }}
                className="group relative overflow-hidden rounded-3xl p-6 text-white font-bold transition-all transform hover:scale-105 hover:shadow-2xl active:scale-95"
                style={{ backgroundColor: char.color }}
              >
                {/* Gradient overlay */}
                <div className="absolute inset-0 bg-gradient-to-br from-white/20 to-black/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                
                {/* Content */}
                <div className="relative z-10 text-center">
                  <div className="text-6xl mb-3 transform group-hover:scale-125 transition-transform duration-300">
                    {char.emoji}
                  </div>
                  <h3 className="text-2xl font-black mb-1">{char.name}</h3>
                  <p className="text-sm opacity-90 mb-3 font-semibold">{char.role}</p>
                  <p className="text-xs opacity-80 leading-relaxed mb-4">{char.description}</p>
                  <div className="flex items-center justify-center gap-2 text-sm font-bold group-hover:translate-x-1 transition-transform">
                    Chat Now <ArrowRight size={16} />
                  </div>
                </div>

                {/* Bottom accent */}
                <div className="absolute bottom-0 left-0 right-0 h-1 bg-white/50 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
              </button>
            ))}
          </div>

          {/* Footer info */}
          <div className="mt-12 text-center text-sm text-gray-600 max-w-2xl mx-auto">
            <p>💡 <span className="font-bold">Tip:</span> Each friend has their own special way of helping. Try them all!</p>
          </div>
        </div>
      </div>
    );
  }
